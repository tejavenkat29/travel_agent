# ============================================================================
# AI Multi-Agent Travel Planner — Environment Variables (TEMPLATE)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
#   cp .env.example .env
# ============================================================================

# ----------------------------- Application ---------------------------------
APP_NAME="AI Travel Planner"
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ------------------------------- Security ----------------------------------
SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --------------------------- LLM provider ----------------------------------
# Which provider the agents use by default: openai | gemini | ollama
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ----------------------------- LangSmith -----------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=travel-planner

# ---------------------------- PostgreSQL -----------------------------------
POSTGRES_USER=travel
POSTGRES_PASSWORD=travel
POSTGRES_DB=travel_planner
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full async DSN (override the discrete vars above if set)
DATABASE_URL=postgresql+asyncpg://travel:travel@localhost:5432/travel_planner

# ------------------------------- Redis -------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ------------------------------- Cache -------------------------------------
CACHE_ENABLED=true
CACHE_BACKEND=redis            # redis | memory
CACHE_TTL_WEATHER=21600        # 6 hours
CACHE_TTL_HOTELS=1800          # 30 minutes
CACHE_TTL_FLIGHTS=300          # 5 minutes

# ------------------------ External travel APIs -----------------------------
# (placeholders for flight / hotel / weather providers used by agent tools)
WEATHER_API_KEY=
FLIGHTS_API_KEY=
HOTELS_API_KEY=
